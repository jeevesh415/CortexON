    "github": {
        "command": "npx",
        "args": [
            "-y",
            "@modelcontextprotocol/server-github"
        ],
        "env": {
            "GITHUB_PERSONAL_ACCESS_TOKEN": "1234"
        },
        "description": "Github",
        "status": "disabled",
        "secret_key": "GITHUB_PERSONAL_ACCESS_TOKEN",
        "tool_analysis": {
            "server_analysis": {
                "server_name": "github",
                "total_tools": 26,
                "analysis_summary": "Comprehensive GitHub API integration tools covering repository management, issue tracking, pull request handling, code search, and collaboration features"
            },
            "tools": [
                {
                    "name": "github.create_or_update_file",
                    "description": "Create or update a single file in a GitHub repository",
                    "parameters": {
                        "required": [
                            "owner",
                            "repo",
                            "path",
                            "content",
                            "message",
                            "branch"
                        ],
                        "optional": [
                            "sha"
                        ],
                        "parameter_details": {
                            "owner": "string - Repository owner (username or organization)",
                            "repo": "string - Repository name",
                            "path": "string - File path in repository",
                            "content": "string - File content",
                            "message": "string - Commit message",
                            "branch": "string - Target branch name",
                            "sha": "string - SHA of existing file when updating"
                        }
                    },
                    "usage": {
                        "format": "github.create_or_update_file(owner='user', repo='repo-name', path='file.txt', content='content', message='commit msg', branch='main')",
                        "example": "github.create_or_update_file(owner='octocat', repo='hello-world', path='docs/README.md', content='# Hello World', message='Add README', branch='main')"
                    },
                    "usefulness": {
                        "primary_use": "File management in GitHub repositories",
                        "use_cases": [
                            "Creating new documentation files",
                            "Updating configuration files",
                            "Managing content through API",
                            "Automated file updates"
                        ],
                        "benefits": "Enables programmatic file management in GitHub repositories without needing git commands"
                    }
                },
                {
                    "name": "github.search_repositories",
                    "description": "Search for GitHub repositories",
                    "parameters": {
                        "required": [
                            "query"
                        ],
                        "optional": [
                            "page",
                            "perPage"
                        ],
                        "parameter_details": {
                            "query": "string - Search query using GitHub search syntax",
                            "page": "number - Page number for pagination",
                            "perPage": "number - Results per page (max 100)"
                        }
                    },
                    "usage": {
                        "format": "github.search_repositories(query='search_term', page=1, perPage=30)",
                        "example": "github.search_repositories(query='language:python stars:>1000', page=1, perPage=50)"
                    },
                    "usefulness": {
                        "primary_use": "Finding relevant GitHub repositories",
                        "use_cases": [
                            "Discovering open source projects",
                            "Research on specific technologies",
                            "Finding trending repositories",
                            "Competitive analysis"
                        ],
                        "benefits": "Enables programmatic discovery and analysis of GitHub repositories based on various criteria"
                    }
                },
                {
                    "name": "github.create_pull_request",
                    "description": "Create a new pull request in a GitHub repository",
                    "parameters": {
                        "required": [
                            "owner",
                            "repo",
                            "title",
                            "head",
                            "base"
                        ],
                        "optional": [
                            "body",
                            "draft",
                            "maintainer_can_modify"
                        ],
                        "parameter_details": {
                            "owner": "string - Repository owner",
                            "repo": "string - Repository name",
                            "title": "string - Pull request title",
                            "head": "string - Branch containing changes",
                            "base": "string - Branch to merge into",
                            "body": "string - Pull request description",
                            "draft": "boolean - Create as draft PR"
                        }
                    },
                    "usage": {
                        "format": "github.create_pull_request(owner='user', repo='repo', title='PR Title', head='feature', base='main')",
                        "example": "github.create_pull_request(owner='octocat', repo='hello-world', title='Add new feature', head='feature-branch', base='main', body='Please review these changes')"
                    },
                    "usefulness": {
                        "primary_use": "Automated pull request creation",
                        "use_cases": [
                            "Automated code review requests",
                            "Dependency updates",
                            "Feature branch merging",
                            "Cross-repository contributions"
                        ],
                        "benefits": "Streamlines the code review and integration process through automated PR creation"
                    }
                }
            ],
            "success": true,
            "discovery_method": "dynamic"
        }
    }
}